<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
    <comment>Base application configuration for com.auth.</comment>
    <entry key="spring.application.name">com.auth</entry>
    <entry key="server.port">8082</entry>
    <entry key="management.tracing.sampling.probability">1.0</entry>
    <entry key="management.endpoints.web.exposure.include">health,info,prometheus</entry>
    <entry key="springdoc.api-docs.path">/openapi</entry>
    <entry key="springdoc.swagger-ui.path">/swagger-ui.html</entry>
    <entry key="logging.level.eu.gridhub">INFO</entry>
</properties>
